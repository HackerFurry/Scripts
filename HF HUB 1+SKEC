-- КНОПКИ ДЛЯ WINBLOCKS
Tabs.ESP:AddButton({
    Title = "Подсветить WinBlock (жёлтый)",
    Description = "Выделяет все WinBlock1-15 ярко-жёлтым цветом",
    Callback = function()
        for i = 1, 15 do
            local block = workspace:FindFirstChild("WinBlock" .. i)
            if block and block:IsA("BasePart") then
                block.Color = Color3.fromRGB(255, 255, 0)
                block.Material = Enum.Material.Neon
            end
        end
    end
})

Tabs.ESP:AddButton({
    Title = "Сбросить цвета WinBlock",
    Description = "Возвращает исходные цвета блоков",
    Callback = function()
        for i = 1, 15 do
            local block = workspace:FindFirstChild("WinBlock" .. i)
            if block and block:IsA("BasePart") then
                block.Color = Color3.fromRGB(255, 255, 255)  -- белый (или любой другой)
                block.Material = Enum.Material.Plastic
            end
        end
    end
})

