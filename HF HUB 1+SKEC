-- Функция создания ESP
local function createESP(adornee, text, color, folderName)
    if not adornee or not adornee.Parent then return nil end

    local oldFolder = adornee:FindFirstChild(folderName)
    if oldFolder then oldFolder:Destroy() end

    local folder = Instance.new("Folder")
    folder.Name = folderName
    folder.Parent = adornee

    local highlight = Instance.new("Highlight")
    highlight.Name = "Highlight"
    highlight.FillColor = color or Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Parent = folder
    highlight.Adornee = adornee

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "Billboard"
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = folder
    billboard.Adornee = adornee
    billboard.Enabled = not hideNames

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.Text = text or "ESP"
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
    label.Parent = billboard

    return folder
end

-- Обновление радуги
local function updateRainbow()
    if not rainbowEnabled then return end
    rainbowHue = (rainbowHue + 0.005) % 1
    local color = Color3.fromHSV(rainbowHue, 1, 1)

    for _, folder in pairs(espObjects.Players) do
        local h = folder:FindFirstChild("Highlight")
        if h then h.FillColor = color end
    end
    for _, folder in pairs(espObjects.WinBlocks) do
        local h = folder:FindFirstChild("Highlight")
        if h then h.FillColor = color end
    end
    for _, folder in pairs(espObjects.Killers) do
        local h = folder:FindFirstChild("Highlight")
        if h then h.FillColor = color end
    end
end

-- Применение скрытия никнеймов
local function applyHideNames()
    for _, folder in pairs(espObjects.Players) do
        local bill = folder:FindFirstChild("Billboard")
        if bill then bill.Enabled = not hideNames end
    end
    for _, folder in pairs(espObjects.WinBlocks) do
        local bill = folder:FindFirstChild("Billboard")
        if bill then bill.Enabled = not hideNames end
    end
    for _, folder in pairs(espObjects.Killers) do
        local bill = folder:FindFirstChild("Billboard")
        if bill then bill.Enabled = not hideNames end
    end
end

-- === ESP ДЛЯ ИГРОКОВ ===
local function updatePlayerESP()
    local enabled = Options.PlayerESP.Value

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end

        if enabled then
            local hp = char:FindFirstChildWhichIsA("Humanoid") and math.floor(char.Humanoid.Health) or 0
            local folder = createESP(char, player.Name .. " | HP: " .. hp, Color3.fromRGB(0, 255, 0), "PlayerESP_Folder")
            if folder then espObjects.Players[player] = folder end
        else
            local folder = char:FindFirstChild("PlayerESP_Folder")
            if folder then folder:Destroy() end
            espObjects.Players[player] = nil
        end
    end
end

-- === ESP ДЛЯ WINBLOCK ===
local function updateWinESP()
    local enabled = Options.WinESP.Value
    local allBlocks = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and string.find(obj.Name, "WinBlock") then
            table.insert(allBlocks, obj)
        end
    end

    for block, folder in pairs(espObjects.WinBlocks) do
        if not block.Parent or not enabled then
            if folder then folder:Destroy() end
            espObjects.WinBlocks[block] = nil
        end
    end

    if enabled then
        for _, block in pairs(allBlocks) do
            if not espObjects.WinBlocks[block] then
                local folder = createESP(block, block.Name, Color3.fromRGB(255, 255, 0), "WinESP_Folder")
                if folder then espObjects.WinBlocks[block] = folder end
            end
        end
    else
        for block, folder in pairs(espObjects.WinBlocks) do
            if folder then folder:Destroy() end
            espObjects.WinBlocks[block] = nil
        end
    end
end

-- === ESP ДЛЯ KILLER (KillBall, Ballerina, Tsunami, WallR, WallL) ===
local function updateKillerESP()
    local enabled = Options.KillerESP.Value

    local targets = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local name = obj.Name
            if name == "KillBall" or 
               name == "BallerinaChocolita" or 
               name == "Ballerina Chocolita" or
               string.find(string.lower(name), "tsunami") or
               name == "WallR" or name == "WallL" then
                table.insert(targets, obj)
            end
        end
    end

    for obj, folder in pairs(espObjects.Killers) do
        if not obj.Parent or not enabled then
            if folder then folder:Destroy() end
            espObjects.Killers[obj] = nil
        end
    end

    if enabled then
        for _, obj in pairs(targets) do
            if not espObjects.Killers[obj] then
                local folder = createESP(obj, obj.Name, Color3.fromRGB(255, 0, 0), "KillerESP_Folder")
                if folder then espObjects.Killers[obj] = folder end
            end
        end
    else
        for obj, folder in pairs(espObjects.Killers) do
            if folder then folder:Destroy() end
            espObjects.Killers[obj] = nil
        end
    end
end

-- Обновление всех ESP
local function refreshAllESP()
    updatePlayerESP()
    updateWinESP()
    updateKillerESP()
    applyHideNames()
end

