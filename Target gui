-- ========== ФУНКЦИИ ПОДСВЕТКИ (тёмно-синий) ==========
local function applyHighlight(target)
    if not highlightEnabled or not target then
        if currentHighlight then
            currentHighlight:Destroy()
            currentHighlight = nil
        end
        return
    end
    
    if target.Character then
        if currentHighlight then currentHighlight:Destroy() end
        local highlight = Instance.new("Highlight")
        highlight.FillColor = Color3.new(0, 0, 0.5)
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color3.new(1, 1, 1)
        highlight.Parent = target.Character
        currentHighlight = highlight
    end
end

local function clearHighlight()
    if currentHighlight then
        currentHighlight:Destroy()
        currentHighlight = nil
    end
end

-- ========== ФУНКЦИИ АИМБОТА ==========
local function aimAtTarget()
    if not aimbotEnabled or not currentTarget or not currentTarget.Character then
        return
    end
    
    local targetChar = currentTarget.Character
    local targetHead = targetChar:FindFirstChild("Head") or targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHead then return end
    
    local cameraPos = camera.CFrame.Position
    local targetPos = targetHead.Position
    local newCFrame = CFrame.new(cameraPos, targetPos)
    camera.CFrame = newCFrame
end

-- ========== ФУНКЦИИ ЦЕЛИ ==========
local function getNearestPlayer()
    local nearest = nil
    local minDist = targetRadius
    local char = plr.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    for _, other in ipairs(game:GetService("Players"):GetPlayers()) do
        if other ~= plr and other.Character then
            local otherRoot = other.Character:FindFirstChild("HumanoidRootPart")
            if otherRoot then
                local dist = (otherRoot.Position - root.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = other
                end
            end
        end
    end
    return nearest
end

local function updateHealthColor(percent)
    if percent >= 0.7 then
        healthFill.BackgroundColor3 = Color3.new(0, 0.5, 1)
    elseif percent >= 0.4 then
        healthFill.BackgroundColor3 = Color3.new(0.3, 0.7, 1)
    elseif percent >= 0.2 then
        healthFill.BackgroundColor3 = Color3.new(0.6, 0.9, 1)
    else
        healthFill.BackgroundColor3 = Color3.new(1, 1, 1)
    end
end

local function updateTargetGUI()
    if not targetEnabled then
        targetFrame.Visible = false
        clearHighlight()
        return
    end

    local nearest = getNearestPlayer()
    currentTarget = nearest

    if not nearest or not nearest.Character then
        targetFrame.Visible = false
        clearHighlight()
        return
    end

    local humanoid = nearest.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        targetFrame.Visible = false
        clearHighlight()
        return
    end

    targetFrame.Visible = true

    displayNameLabel.Text = nearest.DisplayName
    userNameLabel.Text = "@" .. nearest.Name

    local health = humanoid.Health
    local maxHealth = humanoid.MaxHealth
    local percent = health / maxHealth
    healthFill.Size = UDim2.new(percent, 0, 1, 0)
    updateHealthColor(percent)
    healthText.Text = math.floor(percent * 100) .. "%"

    local userId = nearest.UserId
    avatarImage.Image = "rbxthumb://type=AvatarHeadShot&id=" .. userId .. "&w=150&h=150"

    applyHighlight(nearest)
end

-- Отдельный поток для аимбота (чтобы не мешать обновлению GUI)
local aimbotConnection = nil
local function startAimbot()
    if aimbotConnection then aimbotConnection:Disconnect() end
    aimbotConnection = runService.RenderStepped:Connect(function()
        if targetEnabled and aimbotEnabled and currentTarget then
            aimAtTarget()
        end
    end)
end

local function stopAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
end

-- ========== МЕНЮ НАСТРОЕК ==========
mainWindow:Label("TG HF")

mainWindow:Toggle("On", false, function(value)
    targetEnabled = value
    if not value then
        targetFrame.Visible = false
        clearHighlight()
        if updateConnection then
            updateConnection:Disconnect()
            updateConnection = nil
        end
        stopAimbot()
    else
        if not updateConnection then
            updateConnection = runService.RenderStepped:Connect(updateTargetGUI)
        end
        if aimbotEnabled then startAimbot() end
    end
end)

mainWindow:Toggle("Highlight Target", false, function(value)
    highlightEnabled = value
    if not targetEnabled then return end
    if value and currentTarget then
        applyHighlight(currentTarget)
    else
        clearHighlight()
    end
end)

mainWindow:Toggle("Aimbot (head)", false, function(value)
    aimbotEnabled = value
    if not targetEnabled then return end
    if value then
        startAimbot()
    else
        stopAimbot()
    end
end)

