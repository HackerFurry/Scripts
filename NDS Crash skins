-- ТЕЛЕПОРТ КАЖДЫЕ 0.05 СЕКУНДЫ В ТОЧКУ (-307, 179, 314)
-- Остановка по клавише End

local player = game.Players.LocalPlayer
local targetPos = Vector3.new(-307, 179, 314)
local running = true

-- Ф
local function teleport()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid and humanoid.Health <= 0 then return end -- не телепортируем мёртвого
    
    hrp.CFrame = CFrame.new(targetPos)
end

-- СТОП МНЕ НЕ ПРИЯТНО по клавише End
game:GetService("UserInputService").InputBegan:connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.End then
        running = false
        print("Телепорт остановлен")
    end
end)

-- Основной цикл
coroutine.wrap(function()
    while running do
        teleport()
        task.wait(0.05)
    end
end)()

print("Телепорт каждые 0.05 сек в точку (-307, 179, 314) запущен. Нажми End для остановки.")
-- СУПЕР-БЫСТРЫЙ ИНЖЕКТ КЛИКЕРА КАЖДЫЕ 0.5 СЕКУНДЫ (с остановкой старого потока)

local player = game.Players.LocalPlayer
local currentTask = nil

-- клик 
local function runClickerWave()
    -- нафиг окно покупки
    local purchasePrompt = game:GetService("CoreGui"):FindFirstChild("PurchasePromptApp")
    if purchasePrompt then purchasePrompt:Destroy() end
    
    -- выкинул звук
    local mainGui = player.PlayerGui:FindFirstChild("MainGui")
    if mainGui and mainGui:FindFirstChild("HoverSound") then
        mainGui.HoverSound.Volume = 0
    end
    
    -- тапапаем 20000 раз
    local balloon = workspace:FindFirstChild("BillboardBalloon")
    local apple = workspace:FindFirstChild("BillboardApple")
    if not balloon or not apple then return end
    
    local det1 = balloon:FindFirstChild("Board") and balloon.Board:FindFirstChild("ClickDetector")
    local det2 = apple:FindFirstChild("Board") and apple.Board:FindFirstChild("ClickDetector")
    if not det1 or not det2 then return end
    
    for i = 1, 20000 do
        fireclickdetector(det1)
        fireclickdetector(det2)
        if i % 30 == 1 then
            task.wait()
        end
        -- поток выхад
        if not currentTask or currentTask ~= coroutine.running() then
            return
        end
    end
end

-- основная клика
local stopFlag = false
game:GetService("UserInputService").InputBegan:connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.End then
        stopFlag = true
        print("Кликер полностью остановлен")
    end
end)

coroutine.wrap(function()
    while not stopFlag do
        -- Останавливаем предыдущую волну, если она ещё бежит
        if currentTask and coroutine.status(currentTask) ~= "dead" then
            -- Просто сбросим currentTask, старая волна сама выйдет на проверке
            currentTask = nil
        end
        -- волна
        currentTask = coroutine.create(runClickerWave)
        coroutine.resume(currentTask)
        -- ждемс 0.5 секунд
        local start = tick()
        while tick() - start < 0.5 and not stopFlag do
            task.wait()
        end
    end
end)()

print("СУПЕР-КЛИКЕР ЗАПУЩЕН: новая волна каждые 0.5 сек. Нажми End для остановки.")

